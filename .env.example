# ============================================
# GNECT — Environment Variables
# All cloud services are the DEFAULT.
# No local services needed for production.
# ============================================

# Database — Turso (libSQL) for production
DATABASE_URL=

# Chat Service (Socket.io relay) — HuggingFace Space (cloud)
# Default in code: https://verliverli-gnect.hf.space
# For local dev only: http://localhost:3003
CHAT_SERVICE_URL=

# Auth
JWT_SECRET=
ADMIN_NICKNAME=
ADMIN_PASSWORD=

# VAPID keys for Web Push notifications
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Socket.io — HuggingFace Space (cloud relay)
# Default in code: https://verliverli-gnect.hf.space
NEXT_PUBLIC_SOCKET_URL=

# HuggingFace (chat-service deployment)
HUGGINGFACE_SPACE_URL=
HUGGINGFACE_TOKEN=

# Cloudflare Workers — Media proxy via Telegram Bot storage
# Default in code: https://gnect-media-worker.03mrfrancis.workers.dev
CLOUDFLARE_WORKER_URL=
CLOUDFLARE_WORKER_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
